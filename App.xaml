<Application x:Class="CheckerDSO.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- COLORS -->
            <SolidColorBrush x:Key="BgBrush"        Color="#0E0E12"/>
            <SolidColorBrush x:Key="Bg2Brush"       Color="#15151C"/>
            <SolidColorBrush x:Key="Bg3Brush"       Color="#1C1C26"/>
            <SolidColorBrush x:Key="Bg4Brush"       Color="#23232F"/>
            <SolidColorBrush x:Key="BrushBorder"    Color="#2A2A38"/>
            <SolidColorBrush x:Key="BrushBorderHi"  Color="#3D3D52"/>
            <SolidColorBrush x:Key="BorderBrush"    Color="#2A2A38"/>
            <SolidColorBrush x:Key="BorderHiBrush"  Color="#3D3D52"/>


            <SolidColorBrush x:Key="AccentBrush"    Color="#5865F2"/>
            <SolidColorBrush x:Key="AccentHiBrush"  Color="#7289DA"/>
            <SolidColorBrush x:Key="AccentSubBrush" Color="#1A1D3D"/>

            <SolidColorBrush x:Key="GreenBrush"     Color="#2D7A3A"/>
            <SolidColorBrush x:Key="GreenHiBrush"   Color="#3FB950"/>
            <SolidColorBrush x:Key="GreenSubBrush"  Color="#0D2010"/>

            <SolidColorBrush x:Key="YellowBrush"    Color="#9A6C00"/>
            <SolidColorBrush x:Key="YellowHiBrush"  Color="#E3A008"/>
            <SolidColorBrush x:Key="YellowSubBrush" Color="#231800"/>

            <SolidColorBrush x:Key="RedBrush"       Color="#A01919"/>
            <SolidColorBrush x:Key="RedHiBrush"     Color="#F85149"/>
            <SolidColorBrush x:Key="RedSubBrush"    Color="#200D0D"/>

            <SolidColorBrush x:Key="OrangeBrush"    Color="#B45309"/>
            <SolidColorBrush x:Key="OrangeHiBrush"  Color="#F59E0B"/>
            <SolidColorBrush x:Key="OrangeSubBrush" Color="#1C1000"/>

            <SolidColorBrush x:Key="Txt1Brush"      Color="#EEEEF2"/>
            <SolidColorBrush x:Key="Txt2Brush"      Color="#C4C4D0"/>
            <SolidColorBrush x:Key="Txt3Brush"      Color="#7878A0"/>
            <SolidColorBrush x:Key="Txt4Brush"      Color="#44445A"/>

            <!-- ICONS -->
            <Geometry x:Key="Ico_Shield">M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z</Geometry>
            <Geometry x:Key="Ico_Folder">M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z</Geometry>
            <Geometry x:Key="Ico_Proxy">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z</Geometry>
            <Geometry x:Key="Ico_Play">M8 5v14l11-7z</Geometry>
            <Geometry x:Key="Ico_Stop">M6 6h12v12H6z</Geometry>
            <Geometry x:Key="Ico_Export">M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z</Geometry>
            <Geometry x:Key="Ico_Key">M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z</Geometry>
            <Geometry x:Key="Ico_Globe">M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2 0 .68.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.9-4.33-3.56zm2.95-8H5.08c.96-1.66 2.49-2.93 4.33-3.56C8.81 5.55 8.35 6.75 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2 0-.68.07-1.35.16-2h4.68c.09.65.16 1.32.16 2 0 .68-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2 0-.68-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z</Geometry>
            <Geometry x:Key="Ico_Min">M6 19h12v2H6z</Geometry>
            <Geometry x:Key="Ico_Max">M3 3v18h18V3H3zm16 16H5V5h14v14z</Geometry>
            <Geometry x:Key="Ico_Restore">M5 5h14v14H5V5zm9-2H3v16h2V5h9V3z</Geometry>
            <Geometry x:Key="Ico_Close">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</Geometry>

            <!-- BASE TEXTBLOCK -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource Txt1Brush}"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial"/>
                <Setter Property="FontSize"   Value="13"/>
            </Style>

            <!-- SLIM SCROLLBAR -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width"      Value="4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="0,2">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0">
                                            <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border/></ControlTemplate></RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#3D3D52" CornerRadius="2"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0">
                                            <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border/></ControlTemplate></RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- BASE BUTTON -->
            <Style TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource Bg3Brush}"/>
                <Setter Property="Foreground"      Value="{StaticResource Txt2Brush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14,6"/>
                <Setter Property="Margin"          Value="2,2"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg4Brush}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrushBorderHi}"/>

                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg2Brush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Btn_Green" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background"      Value="#1A4D2A"/>
                <Setter Property="BorderBrush"     Value="{StaticResource GreenBrush}"/>
                <Setter Property="Foreground"      Value="{StaticResource GreenHiBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#204F2E"/>
                        <Setter Property="BorderBrush" Value="{StaticResource GreenHiBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="Btn_Red" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background"  Value="#3D1A1A"/>
                <Setter Property="BorderBrush" Value="{StaticResource RedBrush}"/>
                <Setter Property="Foreground"  Value="{StaticResource RedHiBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background"  Value="#4A1F1F"/>
                        <Setter Property="BorderBrush" Value="{StaticResource RedHiBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="Btn_Accent" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background"  Value="{StaticResource AccentBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground"  Value="#FFFFFF"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background"  Value="{StaticResource AccentHiBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AccentHiBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- WIN CONTROL BUTTON -->
            <Style x:Key="Btn_WinCtrl" TargetType="Button">
                <Setter Property="Width"           Value="44"/>
                <Setter Property="Height"          Value="38"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg4Brush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource BorderBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Btn_Close" TargetType="Button" BasedOn="{StaticResource Btn_WinCtrl}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#C42B1C"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- TEXTBOX -->
            <Style TargetType="TextBox">
                <Setter Property="Background"      Value="{StaticResource Bg2Brush}"/>
                <Setter Property="Foreground"      Value="{StaticResource Txt1Brush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="9,6"/>
                <Setter Property="FontSize"        Value="11"/>
                <Setter Property="FontFamily"      Value="Cascadia Mono, Consolas, monospace"/>
                <Setter Property="CaretBrush"      Value="{StaticResource AccentHiBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="Background"      Value="{StaticResource Bg2Brush}"/>
                <Setter Property="Foreground"      Value="{StaticResource Txt1Brush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="9,6"/>
                <Setter Property="FontSize"        Value="11"/>
            </Style>

            <!-- DATAGRID -->
            <Style TargetType="DataGrid">
                <Setter Property="Background"               Value="Transparent"/>
                <Setter Property="BorderThickness"          Value="0"/>
                <Setter Property="RowBackground"            Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0B0B0F"/>
                <Setter Property="Foreground"               Value="{StaticResource Txt2Brush}"/>
                <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1C1C26"/>
                <Setter Property="HeadersVisibility"        Value="Column"/>
                <Setter Property="SelectionMode"            Value="Single"/>
                <Setter Property="FontSize"                 Value="12"/>
                <Setter Property="RowHeaderWidth"           Value="0"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"      Value="#0A0A0E"/>
                <Setter Property="Foreground"      Value="{StaticResource Txt3Brush}"/>
                <Setter Property="Padding"         Value="14,9"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="FontSize"        Value="10"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Height" Value="34"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Bg3Brush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentSubBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource Txt1Brush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="14,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource Txt1Brush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
