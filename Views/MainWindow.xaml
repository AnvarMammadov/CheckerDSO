<Window x:Class="CheckerDSO.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CheckerDSO.ViewModels"
        xmlns:conv="clr-namespace:CheckerDSO.Converters"
        Title="DSO Account Checker"
        Height="800" Width="1160"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" ResizeBorderThickness="5"
                      GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:StatusToColorConverter  x:Key="StatusColor"/>
        <conv:InverseBooleanConverter x:Key="InvBool"/>

        <!-- Sidebar section caption -->
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Txt4Brush}"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="0,14,0,6"/>
        </Style>

        <!-- Sidebar field label -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Txt3Brush}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- Stat row icon+label -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Txt3Brush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Stat row value -->
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>  <!-- title bar -->
            <RowDefinition Height="*"/>   <!-- body -->
            <RowDefinition Height="26"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════  TITLE BAR  ═══════════ -->
        <Border Grid.Row="0"
                Background="#09090D"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0">
                    <Path Data="{StaticResource Ico_Shield}"
                          Fill="{StaticResource AccentHiBrush}"
                          Width="14" Height="14" Stretch="Uniform"
                          Margin="0,0,9,0"/>
                    <TextBlock Text="DSO Account Checker"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource Txt2Brush}"/>
                    <Border Background="{StaticResource AccentSubBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="3"
                            Padding="6,1" Margin="10,0">
                        <TextBlock Text="v1.0" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AccentHiBrush}"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch">
                    <Button Style="{StaticResource Btn_WinCtrl}" Click="MinimizeClick">
                        <Path Data="{StaticResource Ico_Min}" Fill="{StaticResource Txt3Brush}"
                              Width="11" Height="11" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource Btn_WinCtrl}" Click="MaximizeClick">
                        <Path x:Name="MaxIcon" Data="{StaticResource Ico_Max}"
                              Fill="{StaticResource Txt3Brush}"
                              Width="11" Height="11" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource Btn_Close}" Click="CloseClick">
                        <Path Data="{StaticResource Ico_Close}" Fill="{StaticResource Txt3Brush}"
                              Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════  BODY  ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>  <!-- left sidebar -->
                <ColumnDefinition Width="1"/>    <!-- separator -->
                <ColumnDefinition Width="*"/>    <!-- main -->
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT SIDEBAR ─── -->
            <Border Grid.Column="0" Background="#09090D">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,10,16,16">

                        <!-- Total count: big hero number -->
                        <Border Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,12" Margin="0,4,0,12">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="TOTAL" Style="{StaticResource Cap}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding TotalCount}"
                                               FontSize="36" FontWeight="Bold"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               Foreground="{StaticResource Txt1Brush}"/>
                                </StackPanel>
                                <Path Data="{StaticResource Ico_Shield}"
                                      Fill="{StaticResource Bg4Brush}"
                                      Width="30" Height="30" Stretch="Uniform"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- Stats as clean rows -->
                        <TextBlock Text="RESULTS" Style="{StaticResource Cap}"/>

                        <!-- Verified row -->
                        <Border Padding="0,5" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2"
                                            Background="{StaticResource GreenHiBrush}"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Verified" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding VerifiedCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource GreenHiBrush}"/>
                            </Grid>
                        </Border>

                        <!-- Unverified row -->
                        <Border Padding="0,5" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2"
                                            Background="{StaticResource YellowHiBrush}"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Unverified" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding UnverifiedCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource YellowHiBrush}"/>
                            </Grid>
                        </Border>

                        <!-- Wrong Pass row -->
                        <Border Padding="0,5" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2"
                                            Background="{StaticResource RedHiBrush}"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Wrong Pass" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding WrongPassCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource RedHiBrush}"/>
                            </Grid>
                        </Border>

                        <!-- Captcha row -->
                        <Border Padding="0,5">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2"
                                            Background="{StaticResource OrangeHiBrush}"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Captcha" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding CaptchaCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource OrangeHiBrush}"/>
                            </Grid>
                        </Border>

                        <!-- ─── Config ─── -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10"/>

                        <!-- ══ CAPTCHA SOLVER ACCORDION ══ -->
                        <Border x:Name="CaptchaSection" CornerRadius="6"
                                Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Header / Toggle -->
                                <Border x:Name="CaptchaHeader" CornerRadius="6,6,0,0"
                                        Padding="10,8" Cursor="Hand"
                                        MouseLeftButtonUp="CaptchaHeader_Toggle">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Bg3Brush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="{StaticResource Ico_Key}"
                                                  Fill="{StaticResource AccentHiBrush}"
                                                  Width="11" Height="11" Stretch="Uniform"
                                                  Margin="0,0,7,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="CAPTCHA SOLVER"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource Txt2Brush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Chevron -->
                                        <Path x:Name="CaptchaChevron"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Data="M 0,0 L 5,5 L 10,0"
                                              Stroke="{StaticResource Txt4Brush}"
                                              StrokeThickness="1.5" Fill="Transparent"
                                              Width="10" Height="6" Stretch="Uniform"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="CaptchaChevronRotate" Angle="0"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </Border>
                                <!-- Collapsible content -->
                                <StackPanel x:Name="CaptchaContent" Visibility="Collapsed"
                                            Margin="10,0,10,10">
                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="API Key"
                                               FontSize="10" Foreground="{StaticResource Txt3Brush}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding TwoCaptchaApiKey, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="2captcha or CapSolver key"
                                             IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}, FallbackValue=True}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock FontSize="10" Foreground="{StaticResource Txt3Brush}">
                                            <Hyperlink NavigateUri="https://2captcha.com"><Run Text="2captcha"/></Hyperlink>
                                        </TextBlock>
                                        <TextBlock Text=" · " FontSize="10" Foreground="{StaticResource Txt4Brush}"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource Txt3Brush}">
                                            <Hyperlink NavigateUri="https://capsolver.com"><Run Text="CapSolver"/></Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ══ BRIGHTDATA PROXY ACCORDION ══ -->
                        <Border x:Name="BrightSection" CornerRadius="6"
                                Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Header / Toggle -->
                                <Border x:Name="BrightHeader" CornerRadius="6,6,0,0"
                                        Padding="10,8" Cursor="Hand"
                                        MouseLeftButtonUp="BrightHeader_Toggle">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Bg3Brush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="{StaticResource Ico_Globe}"
                                                  Fill="{StaticResource AccentHiBrush}"
                                                  Width="11" Height="11" Stretch="Uniform"
                                                  Margin="0,0,7,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="BRIGHTDATA PROXY"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource Txt2Brush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Chevron -->
                                        <Path x:Name="BrightChevron"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Data="M 0,0 L 5,5 L 10,0"
                                              Stroke="{StaticResource Txt4Brush}"
                                              StrokeThickness="1.5" Fill="Transparent"
                                              Width="10" Height="6" Stretch="Uniform"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="BrightChevronRotate" Angle="0"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </Border>
                                <!-- Collapsible content -->
                                <StackPanel x:Name="BrightContent" Visibility="Collapsed"
                                            Margin="10,0,10,10">
                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Username"
                                               FontSize="10" Foreground="{StaticResource Txt3Brush}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding BrightDataUsername, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="brd-customer-..."
                                             IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}, FallbackValue=True}"/>
                                    <TextBlock Text="Password"
                                               FontSize="10" Foreground="{StaticResource Txt3Brush}"
                                               Margin="0,8,0,4"/>
                                    <PasswordBox x:Name="BrightDataPasswordBox"
                                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}, FallbackValue=True}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Vertical separator -->
            <Border Grid.Column="1" Background="{StaticResource BorderBrush}"/>

            <!-- ─── MAIN AREA ─── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>  <!-- toolbar -->
                    <RowDefinition Height="1"/>   <!-- separator -->
                    <RowDefinition Height="*"/>   <!-- datagrid -->
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0"
                        Background="{StaticResource Bg2Brush}"
                        Padding="12,0">
                    <Grid VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <Button Command="{Binding LoadLogsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Ico_Folder}"
                                          Fill="{StaticResource Txt3Brush}"
                                          Width="13" Height="13" Stretch="Uniform"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="Load Accounts" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding LoadProxiesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Ico_Proxy}"
                                          Fill="{StaticResource Txt3Brush}"
                                          Width="13" Height="13" Stretch="Uniform"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="Load Proxies" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Border Width="1" Background="{StaticResource BorderBrush}"
                                    Margin="8,10"/>

                            <Button Command="{Binding StartCommand}"
                                    Style="{StaticResource Btn_Green}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Ico_Play}"
                                          Fill="{StaticResource GreenHiBrush}"
                                          Width="12" Height="12" Stretch="Uniform"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="Start" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource GreenHiBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding StopCommand}"
                                    Style="{StaticResource Btn_Red}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Ico_Stop}"
                                          Fill="{StaticResource RedHiBrush}"
                                          Width="11" Height="11" Stretch="Uniform"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="Stop" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource RedHiBrush}"/>
                                </StackPanel>
                            </Button>

                            <Border Width="1" Background="{StaticResource BorderBrush}"
                                    Margin="8,10"/>

                            <Button Command="{Binding ExportUnverifiedCommand}"
                                    Style="{StaticResource Btn_Accent}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Ico_Export}"
                                          Fill="White" Width="12" Height="12"
                                          Stretch="Uniform" Margin="0,0,6,0"/>
                                    <TextBlock Text="Export Unverified" FontSize="12"
                                               FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Threads (right side) -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="THREADS" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource Txt4Brush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Background="{StaticResource AccentSubBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="10,3" Margin="0,0,10,0">
                                <TextBlock Text="{Binding ThreadCount}"
                                           Foreground="{StaticResource AccentHiBrush}"
                                           FontWeight="Bold" FontSize="14"
                                           FontFamily="Cascadia Mono, Consolas"/>
                            </Border>
                            <Slider Minimum="1" Maximum="50"
                                    Value="{Binding ThreadCount}"
                                    Width="100" VerticalAlignment="Center"
                                    IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}, FallbackValue=True}">
                                <Slider.Template>
                                    <ControlTemplate TargetType="Slider">
                                        <Grid Height="20">
                                            <Border Height="3" CornerRadius="2" VerticalAlignment="Center"
                                                    Background="{StaticResource BorderBrush}"/>
                                            <Track x:Name="PART_Track">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="Slider.DecreaseLarge">
                                                        <RepeatButton.Template>
                                                            <ControlTemplate TargetType="RepeatButton">
                                                                <Border Height="3" CornerRadius="2" VerticalAlignment="Center"
                                                                        Background="{StaticResource AccentBrush}"/>
                                                            </ControlTemplate>
                                                        </RepeatButton.Template>
                                                    </RepeatButton>
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb Width="13" Height="13">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Ellipse Fill="{StaticResource AccentHiBrush}"
                                                                         Stroke="{StaticResource BgBrush}"
                                                                         StrokeThickness="2"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="Slider.IncreaseLarge">
                                                        <RepeatButton.Template>
                                                            <ControlTemplate TargetType="RepeatButton">
                                                                <Border Background="Transparent"/>
                                                            </ControlTemplate>
                                                        </RepeatButton.Template>
                                                    </RepeatButton>
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Slider.Template>
                            </Slider>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Toolbar bottom line -->
                <Border Grid.Row="1" Background="{StaticResource BorderBrush}"/>

                <!-- DataGrid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Accounts}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True"
                          BorderThickness="0" Background="Transparent"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="USERNAME" Width="2.2*" Binding="{Binding Email}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
                                    <Setter Property="FontSize"   Value="12"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt1Brush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="PASSWORD" Width="1.2*" Binding="{Binding Password}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
                                    <Setter Property="FontSize"   Value="12"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt3Brush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="STATUS" Width="105">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="8,2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource Bg3Brush}"
                                            Margin="4,0">
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="10" FontWeight="Bold"
                                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColor}}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="NOTES" Width="*" Binding="{Binding Notes}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize"   Value="11"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt3Brush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ═══════════  STATUS BAR  ═══════════ -->
        <Border Grid.Row="2" Background="#09090D"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Margin="0,0,7,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Txt4Brush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource GreenHiBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="11" Foreground="{StaticResource Txt3Brush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <TextBlock FontSize="11">
                        <Run Text="V:" Foreground="{StaticResource Txt4Brush}"/>
                        <Run Text="{Binding VerifiedCount}" Foreground="{StaticResource GreenHiBrush}"/>
                        <Run Text="   U:" Foreground="{StaticResource Txt4Brush}"/>
                        <Run Text="{Binding UnverifiedCount}" Foreground="{StaticResource YellowHiBrush}"/>
                        <Run Text="   W:" Foreground="{StaticResource Txt4Brush}"/>
                        <Run Text="{Binding WrongPassCount}" Foreground="{StaticResource RedHiBrush}"/>
                        <Run Text="   C:" Foreground="{StaticResource Txt4Brush}"/>
                        <Run Text="{Binding CaptchaCount}" Foreground="{StaticResource OrangeHiBrush}"/>
                        <Run Text="   /" Foreground="{StaticResource Txt4Brush}"/>
                        <Run Text="{Binding TotalCount}" Foreground="{StaticResource Txt2Brush}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
